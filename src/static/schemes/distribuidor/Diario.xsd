													<xs:pattern value="DUC[-]{1}DIS[-]{1}[0-9]{4}"/>
													<xs:pattern value="DUC[-]{1}CAR[-]{1}[0-9]{4}"/>
													<xs:pattern value="DUC[-]{1}DES[-]{1}[0-9]{4}"/>
													<xs:pattern value="DUC[-]{1}ETA[-]{1}[0-9]{4}"/>
													<xs:pattern value="DUC[-]{1}SDA[-]{1}[0-9]{4}"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="DescripcionDucto">
											<xs:annotation>
												<xs:documentation>Requerido para expresar la localización y/o descripción de cada ducto (ejemplo: llegada a centro procesador de gas). Tratándose de ductos de distribución deberá describirse el sistema.</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:minLength value="2"/>
													<xs:maxLength value="250"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="DiametroDucto">
											<xs:annotation>
												<xs:documentation>Requerido para expresar el diámetro nominal, en pulgadas. Deberá tener un valor mínimo de 1 a 200.</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:decimal">
													<xs:minInclusive value="1.000"/>
