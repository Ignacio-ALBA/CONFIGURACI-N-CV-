			<xs:assert test="every $p in Covol:PRODUCTO satisfies  (((Covol:Caracter/Covol:TipoCaracter = 'contratista' or Covol:Caracter/Covol:TipoCaracter = 'asignatario') and ($p/Covol:ClaveProducto = 'PR09' or $p/Covol:ClaveProducto = 'PR10')) or not($p/Covol:GasNatural/Covol:GasNaturalOCondensados))"/>
			<xs:assert test="every $p in Covol:PRODUCTO satisfies not ((Covol:Caracter/Covol:TipoCaracter = 'contratista' or Covol:Caracter/Covol:TipoCaracter = 'asignatario') and ($p/Covol:ClaveProducto = 'PR08')) or ($p/Covol:Petroleo)"/>
			<xs:assert test="every $p in Covol:PRODUCTO satisfies ((Covol:Caracter/Covol:TipoCaracter = 'contratista' or Covol:Caracter/Covol:TipoCaracter = 'asignatario') and ($p/Covol:ClaveProducto = 'PR08')) or not ($p/Covol:Petroleo)"/>
			<xs:assert test="every $p in Covol:PRODUCTO satisfies not ((Covol:Caracter/Covol:TipoCaracter = 'usuario' or Covol:Caracter/Covol:TipoCaracter = 'permisionario') and ($p/Covol:ClaveProducto = 'PR09' or $p/Covol:ClaveProducto = 'PR10')) or not($p/Covol:GasNatural/Covol:GasNaturalOCondensados)"/>
		</xs:complexType>
	</xs:element>
