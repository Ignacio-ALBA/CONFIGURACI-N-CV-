																				</xs:annotation>
																			</xs:element>
																		</xs:sequence>
																	</xs:complexType>
																</xs:element>
																<xs:element name="VolumenFinalTanque">
																	<xs:annotation>
																		<xs:documentation>Requerido para expresar el volumen final después de la entrega del producto por cada operación de venta, entrega, suministro o exportación (cantidad expresada en litros tratándose de petrolíferos, pie cúbico tratándose de gas natural para contratistas y asignatarios, metro cúbico tratándose de gas natural en los demás casos, barril tratándose de petróleo y condensados).</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:sequence>
																			<xs:element name="ValorNumerico">
																				<xs:annotation>
																					<xs:documentation>Valor adimensional del volumen.</xs:documentation>
																				</xs:annotation>
