													<xs:element name="TotalRecepciones">
														<xs:annotation>
															<xs:documentation>Requerido para expresar el total de recepciones en el cabezal de pozo o ducto de recolección, la estación de proceso, en la refinería, en la terminal de almacenamiento o área de almacenamiento para usos propios, en la instalación fija para recibir gas natural, en los ductos de transporte y distribución, en los medios de transporte o distribución distintos a ductos o en la estación de servicio.</xs:documentation>
														</xs:annotation>
