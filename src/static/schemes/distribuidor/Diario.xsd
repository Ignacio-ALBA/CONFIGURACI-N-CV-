													<xs:whiteSpace value="collapse"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="MedicionDucto" maxOccurs="unbounded">
											<xs:complexType>
												<xs:group ref="ns:MedicionDucto"/>
											</xs:complexType>
										</xs:element>
										<xs:element name="CapacidadGasTalon" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Condicional para aquellos que hayan señalado la clave de producto PR09 para expresar el nivel mínimo operativo de las redes de transporte del sistema gasista. Esta cantidad corresponderá al nivel mínimo de llenado de los gasoductos de transporte, traducida en días de utilización.</xs:documentation>
