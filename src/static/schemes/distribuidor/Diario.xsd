														</xs:complexType>
													</xs:element>
													<xs:element name="TotalDocumentos">
														<xs:annotation>
															<xs:documentation>Requerido para expresar el total de documentos que amparen las entregas por ventas, autoconsumo o por prestaciones de servicio.</xs:documentation>
