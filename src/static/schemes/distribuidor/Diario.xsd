																								</xs:restriction>
																							</xs:simpleType>
																						</xs:element>
																						<xs:element name="UM" type="ns:UM">
																							<xs:annotation>
																								<xs:documentation>Unidad de medida asociada al valor numérico.</xs:documentation>
																							</xs:annotation>
																						</xs:element>
																					</xs:sequence>
																				</xs:complexType>
																			</xs:element>
																			<xs:element name="PrecioVentaTotalizadorInsta" minOccurs="0">
