																						<xs:maxInclusive value="100000000000.00000"/>
																						<xs:whiteSpace value="collapse"/>
																						<xs:fractionDigits value="5"/>
																					</xs:restriction>
																				</xs:simpleType>
																			</xs:element>
																			<xs:element name="UM" type="ns:UM">
																				<xs:annotation>
																					<xs:documentation>Unidad de medida asociada al valor numérico.</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																		</xs:sequence>
																	</xs:complexType>
																</xs:element>
																<xs:element name="Temperatura">
																	<xs:annotation>
																		<xs:documentation>Requerido para expresar la temperatura del tanque a la que se realizó la cuantificación y/o totalización de la masa o volumen del hidrocarburo o petrolífero de que se trate, tomando en consideración las condiciones de referencia La unidad de medida es grados Celsius.</xs:documentation>
																	</xs:annotation>
																	<xs:simpleType>
																		<xs:restriction base="xs:decimal">
																			<xs:minInclusive value="-170.000"/>
