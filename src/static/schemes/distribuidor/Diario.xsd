			<xs:assert test=" if ((Covol:PRODUCTO/ClaveProducto = 'PR09') and (Covol:NumeroDuctosEntradaSalida or Covol:NumeroDuctosTransporteDistribucion)) then (Covol:DUCTO/Covol:CapacidadGasTalon and Covol:DUCTO/Covol:UMCCapacidadGasTalon)
									else not(Covol:DUCTO/Covol:CapacidadGasTalon and Covol:DUCTO/Covol:UMCCapacidadGasTalon)"/>
			<xs:assert test="if (string-length(Covol:RfcContribuyente) =12) then (Covol:RfcRepresentanteLegal) else not(Covol:RfcRepresentanteLegal)"/>
			<xs:assert test="if (Covol:NumeroTanques>0) then (Covol:PRODUCTO/Covol:TANQUE)
