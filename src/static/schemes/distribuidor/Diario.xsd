													<xs:element name="SumaVolumenRecepcion">
														<xs:annotation>
															<xs:documentation>Requerido para expresar la suma del volumen recibido por compras o por prestaciones de servicio (cantidad expresada en litros tratándose de petrolíferos, pie cúbico tratándose de gas natural para contratistas y asignatarios, metro cúbico tratándose de gas natural en los demás casos, barril tratándose de petróleo y condensados).</xs:documentation>
														</xs:annotation>
