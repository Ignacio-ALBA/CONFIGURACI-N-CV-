			else not(Covol:PRODUCTO/Covol:POZO)"/>
			<xs:assert test="if (Covol:NumeroDuctosEntradaSalida>0 or Covol:NumeroDuctosTransporteDistribucion>0) then (Covol:PRODUCTO/Covol:DUCTO)
			else not(Covol:PRODUCTO/Covol:DUCTO)"/>
			<xs:assert test="if (Covol:NumeroDispensarios>0) then (Covol:PRODUCTO/Covol:DISPENSARIO)
