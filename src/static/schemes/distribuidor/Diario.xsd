																						<xs:maxInclusive value="100000000000.00000"/>
																						<xs:whiteSpace value="collapse"/>
																						<xs:fractionDigits value="5"/>
																					</xs:restriction>
																				</xs:simpleType>
																			</xs:element>
																			<xs:element name="UM" type="ns:UM">
																				<xs:annotation>
																					<xs:documentation>Unidad de medida asociada al valor numérico.</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																		</xs:sequence>
																	</xs:complexType>
																</xs:element>
																<xs:element name="VolumenRecepcion">
																	<xs:annotation>
																		<xs:documentation>Requerido para expresar la cantidad de producto recibido por operación de compra, recepción, recolección o importación (cantidad expresada en litros tratándose de petrolíferos, pie cúbico tratándose de gas natural para contratistas y asignatarios, metro cúbico tratándose de gas natural en los demás casos, barril tratándose de petróleo y condensados).</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:sequence>
																			<xs:element name="ValorNumerico">
																				<xs:annotation>
																					<xs:documentation>Valor adimensional del volumen.</xs:documentation>
																				</xs:annotation>
																				<xs:simpleType>
																					<xs:restriction base="xs:decimal">
