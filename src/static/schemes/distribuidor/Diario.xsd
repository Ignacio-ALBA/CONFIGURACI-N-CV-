<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:Covol="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios" xmlns:ns="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios" xmlns:tr="Complemento_Transporte" xmlns:alm="Complemento_Almacenamiento" xmlns:CDLRGN="Complemento_CDLRGN" xmlns:co="Complemento_Comercializacion" xmlns:dis="Complemento_Distribucion" xmlns:exp="Complemento_Expendio" xmlns:ext="Complemento_Extraccion" xmlns:ref="Complemento_Refinacion" xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning" targetNamespace="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios" elementFormDefault="qualified" attributeFormDefault="unqualified" vc:minVersion="1.1">
    <xs:import schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Catalogo.xsd"/>
	<xs:import namespace="Complemento_Transporte" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Transporte.xsd"/>
	<xs:import namespace="Complemento_Almacenamiento" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Almacenamiento.xsd"/>
	<xs:import namespace="Complemento_CDLRGN" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/CDLRGN.xsd"/>
	<xs:import namespace="Complemento_Comercializacion" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Comercializacion.xsd"/>
	<xs:import namespace="Complemento_Distribucion" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Distribucion.xsd"/>
	<xs:import namespace="Complemento_Expendio" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Expendio.xsd"/>
	<xs:import namespace="Complemento_Extraccion" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Extraccion.xsd"/>
	<xs:import namespace="Complemento_Refinacion" schemaLocation="https://repositorio.cloudb.sat.gob.mx/Covol/xml/Diarios/Refinacion.xsd"/>
	<xs:element name="ControlesVolumetricos">
		<xs:annotation>
			<xs:documentation>Estándar para Controles Volumétricos</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Version" fixed="1.0">
					<xs:annotation>
						<xs:documentation>Requerido para todos los contribuyentes, debe expresar la versión del programa informático que genera el XML.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:minLength value="1"/>
							<xs:maxLength value="5"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="RfcContribuyente">
					<xs:annotation>
						<xs:documentation>Requerido para todos los contribuyentes, para expresar su RFC. Puede ser de persona moral o física.</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:simpleContent>
							<xs:extension base="t_RFC"/>
						</xs:simpleContent>
					</xs:complexType>
				</xs:element>
				<xs:element name="RfcRepresentanteLegal" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Condicional para todos los contribuyentes que sean persona moral, para expresar el RFC de su representante legal. El RFC deberá contener 13 caracteres al tratarse de una persona física.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:whiteSpace value="collapse"/>
							<xs:pattern value="[A-ZÑ&amp;]{4}[0-9]{2}(0[1-9]|1[0-2])([12][0-9]|0[1-9]|3[01])[A-Z0-9]{3}"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="RfcProveedor">
					<xs:annotation>
						<xs:documentation>Requerido para todos los contribuyentes, para expresar el RFC del proveedor del programa informático para llevar controles volumétricos. El RFC podrá contener 12 o 13 caracteres.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:whiteSpace value="collapse"/>
							<xs:pattern value="[A-ZÑ&amp;]{3,4}[0-9]{2}(0[1-9]|1[0-2])([12][0-9]|0[1-9]|3[01])[A-Z0-9]{3}"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="RfcProveedores" minOccurs="0" maxOccurs="unbounded">
					<xs:annotation>
						<xs:documentation>Opcional para expresar el RFC de los proveedores de equipos, sistemas, programas o cualquier otro componente de los controles volumétricos. El RFC deberá contener 12 ó 13 caracteres. Este campo deberá repetirse por cada proveedor con que se cuente.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:whiteSpace value="collapse"/>
							<xs:pattern value="[A-ZÑ&amp;]{3,4}[0-9]{2}(0[1-9]|1[0-2])([12][0-9]|0[1-9]|3[01])[A-Z0-9]{3}"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="Caracter">
					<xs:annotation>
						<xs:documentation>Nodo requerido para expresar la calidad o el carácter con el que el contribuyente obligado a llevar controles volumétricos actúa para efectos regulatorios.</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="TipoCaracter" type="c_Caracter">
								<xs:annotation>
									<xs:documentation>Requerido para expresar el carácter con el que actúa para efectos regulatorios.</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="ModalidadPermiso" type="t_clavePermisos" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional cuando en el elemento “TipoCaracter” se haya seleccionado “permisionario”, para expresar el tipo de permiso conforme a lo señalado en la sección 4. “VALIDACIONES ADICIONALES A REALIZAR”, subsección 4.1 “Tipo definido para los tipos de permisos”.			</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="NumPermiso" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional cuando en el elemento “TipoCaracter” se haya seleccionado “permisionario” para expresar el número de permiso otorgado por la Comisión Reguladora de Energía o la Secretaría de Energía, siguiendo el patrón asociado al permiso, conforme a la sección 4. “VALIDACIONES ADICIONALES A REALIZAR”, subsección 4.1 “Tipo definido para los tipos de permisos”.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="t_NumPermisoContratoAsignacion"/>
								</xs:simpleType>
							</xs:element>
							<xs:element name="NumContratoOAsignacion" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional cuando en el elemento “TipoCaracter” se haya seleccionado “contratista” o “asignatario” para expresar el número de asignación otorgada por la Secretaría de Energía o el número de contrato celebrado con la Comisión Nacional de Hidrocarburos, según corresponda.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:minLength value="14"/>
										<xs:maxLength value="24"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="InstalacionAlmacenGasNatural" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional cuando en el elemento “TipoCaracter” se haya seleccionado “usuario”, para identificar de forma descriptiva la instalación que recibe, almacena, entrega o usa hidrocarburos o petrolíferos.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:minLength value="16"/>
										<xs:maxLength value="250"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
						</xs:sequence>
						<xs:assert test="if (Covol:TipoCaracter = 'permisionario')then
          if((Covol:ModalidadPermiso='PER1') and matches(Covol:NumPermiso,'^H[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER2') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ES[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER3') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ES[/]{1}[MM]{2}[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER4') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ESA[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER5') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}DIS[/]{1}OM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER6') and matches(Covol:NumPermiso,'^H[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER7') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[OM]{2}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER8') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[DUC]{3}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER9') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[TM]{2}[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER10') and matches(Covol:NumPermiso,'^PQ[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[DUC]{3}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER11') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER12') and matches(Covol:NumPermiso,'^PQ[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER13') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[AE]{2}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER14') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}[AE]{2}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER15') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[0-9]{4}$')) then true()         
          else if((Covol:ModalidadPermiso='PER16') and matches(Covol:NumPermiso,'^P[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER17') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[GN]{2}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER18') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[PETRO]{1,5}[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER19') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[CEE]{3}[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER20') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}COMP[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER21') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}DESC[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER22') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}DIS[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER23') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}DIS[/]{1}OM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER24') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ES[/]{1}FE[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER25') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ES[/]{1}MM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER26') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}GES[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER27') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}LICUE[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER28') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}REG[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER29') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}TUP[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER30') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}SAB[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER31') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}OM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER32') and matches(Covol:NumPermiso,'^P[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}TM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER33') and matches(Covol:NumPermiso,'^P[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}OM[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER34') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER35') and matches(Covol:NumPermiso,'^GN[/]{1}[0-9]{1,5}[/]{1}P[/]{1}TRA[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER36') and matches(Covol:NumPermiso,'^GN[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}DUC[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER37') and matches(Covol:NumPermiso,'^P[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER38') and matches(Covol:NumPermiso,'^P[/]{1}[0-9]{1,5}[/]{1}[P]{1}[/]{1}TRA[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER39') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}DIST[/]{1}AUT[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER40') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}DIST[/]{1}PLA[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER41') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}DIST[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER42') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}LPD[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER43') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ES[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER44') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}AUT[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER45') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}COM[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER46') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER47') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}LPT[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER48') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}TRA[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER49') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}ALM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER50') and matches(Covol:NumPermiso,'^G[/]{1}[0-9]{1,5}[/]{1}LPA[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER51') and matches(Covol:NumPermiso,'^LP[/]{1}[0-9]{1,5}[/]{1}DIST[/]{1}REP[/]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER52') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}EXP[/]{1}ESA[/]{1}MM[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER53') and matches(Covol:NumPermiso,'^PL[/]{1}[0-9]{1,5}[/]{1}DIS[/]{1}DUC[/]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER54') and matches(Covol:NumPermiso,'^SENER[-]{1}REF[-]{1}[0-9]{3}[-]{1}[0-9]{4}$')) then true()          
          else if((Covol:ModalidadPermiso='PER55') and matches(Covol:NumPermiso,'^SENER[-]{1}TP[-]{1}[0-9]{3}[-]{1}[0-9]{4}$')) then true()
          else if((Covol:ModalidadPermiso='PER56') and matches(Covol:NumPermiso,'^SENER[-]{1}CPG[-]{1}[0-9]{3}[-]{1}[0-9]{4}$')) then true()
          
          else false()
          
          
          else true()
            "/>
						<xs:assert test="if (Covol:TipoCaracter = 'permisionario') then(Covol:ModalidadPermiso and Covol:NumPermiso) and not(Covol:NumContratoOAsignacion) and not(Covol:InstalacionAlmacenGasNatural)
									else  if (Covol:TipoCaracter = 'usuario') 
									then (Covol:InstalacionAlmacenGasNatural)
									and not(Covol:ModalidadPermiso) 
									and not(Covol:NumContratoOAsignacion) 
									and not(Covol:NumeroPermiso) 
									else  if (Covol:TipoCaracter = 'asignatario' or Covol:TipoCaracter = 'contratista') 
									then (Covol:NumContratoOAsignacion)
									and not(Covol:ModalidadPermiso) 
									and not(Covol:NumeroPermiso) 
									and not(Covol:InstalacionAlmacenGasNatural) 
									else true()"/>
					</xs:complexType>
				</xs:element>
				<xs:element name="ClaveInstalacion" type="c_ClaveInstalacion">
					<xs:annotation>
						<xs:documentation>Requerido para expresar la clave de identificación de la instalación o proceso donde deban instalarse sistemas de medición, conforme a la sección 5 “Claves”, subsección 5.1.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DescripcionInstalacion">
					<xs:annotation>
						<xs:documentation>Requerido para describir la instalación o proceso donde deban instalarse sistemas de medición.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:minLength value="5"/>
							<xs:maxLength value="250"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="Geolocalizacion" minOccurs="0" maxOccurs="unbounded">
					<xs:annotation>
						<xs:documentation>Nodo opcional, para registrar la ubicación geográfica (Latitud y Longitud) de la instalación expresada en Grados decimales (DD), con los elementos GeolocalizacionLatitud y GeolocalizacionLongitud. Para el caso de áreas Contractuales o Asignaciones se deberán indicar las coordenadas de cada vértice.</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="GeolocalizacionLatitud">
								<xs:annotation>
									<xs:documentation>Requerido para expresar la ubicación geográfica de la instalación, expresada en Grados decimales (DD). Para el caso de áreas Contractuales o Asignaciones se deberán indicar las coordenadas de cada vértice. Este elemento se puede repetir por cada vértice del área o asignación.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:decimal">
										<xs:minInclusive value="-90"/>
										<xs:maxInclusive value="90"/>
										<xs:fractionDigits value="7"/>
										<xs:whiteSpace value="collapse"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="GeolocalizacionLongitud">
								<xs:annotation>
									<xs:documentation>Requerido para expresar la ubicación geográfica de la instalación expresada en Grados decimales (DD). Para el caso de áreas Contractuales o Asignaciones se deberán indicar las coordenadas de cada vértice. Este elemento se puede repetir por cada vértice del área o asignación.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:decimal">
										<xs:minInclusive value="-180"/>
										<xs:maxInclusive value="180"/>
										<xs:whiteSpace value="collapse"/>
										<xs:fractionDigits value="7"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="NumeroPozos" type="xs:int">
					<xs:annotation>
						<xs:documentation>Requerido para expresar el número de pozos que cuentan con sistemas de medición a boca de pozo. En caso de no tener debe manifestar 0.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="NumeroTanques" type="xs:int">
					<xs:annotation>
						<xs:documentation>Requerido para expresar el número de tanques con los que cuenta o, en su caso, módulos. Incluye cualquier medio de almacenamiento, transporte o distribución en los que se almacenen hidrocarburos o petrolíferos, tales como tanques, autotanques, carrotanques, buquetanques o en caso de que el punto de medición aprobado o determinado por la CNH sea un medio de almacenamiento, En caso de no tener debe manifestar 0.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="NumeroDuctosEntradaSalida" type="xs:int">
					<xs:annotation>
						<xs:documentation>Requerido para expresar el número de ductos de entrada y salida a medios de almacenamiento o de carga y descarga a medios de transporte o distribución con los que cuenta o en caso de que el punto de medición aprobado o determinado por la CNH sea un ducto. En caso de no tener debe manifestar 0.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="NumeroDuctosTransporteDistribucion" type="xs:int">
					<xs:annotation>
						<xs:documentation>Requerido para expresar el número de ductos de transporte o distribución con los que cuenta o en caso de que el punto de medición aprobado o determinado por la CNH sea un ducto. En caso de no tener debe manifestar 0.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="NumeroDispensarios" type="xs:int">
					<xs:annotation>
						<xs:documentation>Requerido para expresar el número de dispensarios con los que cuenta. En caso de no tener debe manifestar “0”.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="FechaYHoraCorte" type="t_FechaHusoHorario">
					<xs:annotation>
						<xs:documentation>Requerido para expresar la fecha y hora que corresponde a la información que se reporta, deberá expresarse la hora en UTC con la indicación del huso horario yyyy-mm-ddThh:mm:ss+-hh:mm, de acuerdo con la especificación ISO 8601.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="PRODUCTO" maxOccurs="unbounded">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="ClaveProducto" type="c_claveProductos">
								<xs:annotation>
									<xs:documentation>Requerido para expresar la clave del producto conforme a lo señalado en el catálogo c_claveProductos, en la sección 4. “VALIDACIONES ADICIONALES A REALIZAR”, subsección 4.2 “Tipo definido para los productos”.
									</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="ClaveSubProducto" type="c_claveSubproductos" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional cuando hayan seleccionado los productos PR03, PR07, PR08, PR09, PR11, PR13, PR15, PR16, PR17, PR18, PR19 u PR20, para expresar la clave del subproducto conforme a lo señalado en el catálogo c_claveSubproductos, en la sección 4. “VALIDACIONES ADICIONALES A REALIZAR”, subsección 4.2 “Tipo definido para los productos”.
									</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:choice>
								<xs:element name="Gasolina" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="ComposOctanajeGasolina" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR07. Deberá tener un valor mínimo de 70 y un máximo de 130.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:int">
														<xs:minInclusive value="70"/>
														<xs:maxInclusive value="130"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
											<xs:element name="GasolinaConCombustibleNoFosil" type="c_CondicionalSeleccionar" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR07 para expresar si el producto contiene combustible no fósil.</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="ComposDeCombustibleNoFosilEnGasolina" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya declarado “Sí” en el elemento “GasolinaConCombustibleNoFosil”, para expresar el porcentaje de combustible no fósil contenido en el producto. Deberá tener un valor mínimo de 1 a 99.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:int">
														<xs:minInclusive value="1"/>
														<xs:maxInclusive value="99"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
										</xs:sequence>
										<xs:assert test="if (Covol:GasolinaConCombustibleNoFosil = 'Si') then (Covol:ComposDeCombustibleNoFosilEnGasolina) else not(Covol:ComposDeCombustibleNoFosilEnGasolina)"/>
									</xs:complexType>
								</xs:element>
								<xs:element name="Diesel" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="DieselConCombustibleNoFosil" type="c_CondicionalSeleccionar">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR03 para expresar si el producto contiene combustible no fósil.</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="ComposDeCombustibleNoFosilEnDiesel" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya declarado “Sí” en el elemento “DieselConCombustibleNoFosil”, para expresar el porcentaje de combustible no fósil contenido en el producto. Deberá tener un valor mínimo de 1 a 99.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:int">
														<xs:minInclusive value="1"/>
														<xs:maxInclusive value="99"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
										</xs:sequence>
										<xs:assert test="if (Covol:DieselConCombustibleNoFosil ='Si') then (Covol:ComposDeCombustibleNoFosilEnDiesel) 
	                      else if (Covol:DieselConCombustibleNoFosil ='No') then not(Covol:ComposDeCombustibleNoFosilEnDiesel) 
		else true()"/>
									</xs:complexType>
								</xs:element>
								<xs:element name="Turbosina" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="TurbosinaConCombustibleNoFosil" type="c_CondicionalSeleccionar">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR11 para expresar si el producto contiene combustible no fósil.</xs:documentation>
												</xs:annotation>
											</xs:element>
											<xs:element name="ComposDeCombustibleNoFosilEnTurbosina" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya declarado “Sí” en el elemento “TurbosinaConCombustibleNoFosil”, para expresar el porcentaje de combustible no fósil contenido en el producto. Deberá tener un valor mínimo de 1 a 99.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:int">
														<xs:minInclusive value="1"/>
														<xs:maxInclusive value="99"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
										</xs:sequence>
										<xs:assert test="if (Covol:TurbosinaConCombustibleNoFosil = 'Si') then (Covol:ComposDeCombustibleNoFosilEnTurbosina) else not(Covol:ComposDeCombustibleNoFosilEnTurbosina)"/>
									</xs:complexType>
								</xs:element>
								<xs:element name="GasLP" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="ComposDePropanoEnGasLP">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR12, para expresar el porcentaje normalizado de propano en el gas licuado de petróleo, conforme a los resultados del dictamen emitido por el proveedor del servicio de emisión de dictámenes que determinen el tipo de hidrocarburo o petrolífero de que se trate. Deberá tener un valor mínimo de 0.01 a 99.99.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:decimal">
														<xs:minInclusive value="0.01"/>
														<xs:maxInclusive value="99.99"/>
														<xs:fractionDigits value="2"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
											<xs:element name="ComposDeButanoEnGasLP">
												<xs:annotation>
													<xs:documentation>Condicional en caso de que haya seleccionado el producto PR12, para expresar el porcentaje normalizado de butano en el gas licuado de petróleo, conforme a los resultados del dictamen emitido por el proveedor del servicio de emisión de dictámenes que determinen el tipo de hidrocarburo o petrolífero de que se trate. Deberá tener un valor mínimo de 0.01 a 99.99.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:decimal">
														<xs:minInclusive value="0.01"/>
														<xs:maxInclusive value="99.99"/>
														<xs:fractionDigits value="2"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="Petroleo" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="DensidadDePetroleo">
												<xs:annotation>
													<xs:documentation>Condicional tratándose de sujetos que hayan manifestado ser “contratista” o “asignatario” en el elemento “TipoCaracter”, en caso de que haya seleccionado el producto PR08, para expresar la densidad del petróleo, expresada en °API. Deberá tener un valor mínimo de 0.1 a 80.0.										</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:decimal">
														<xs:minInclusive value="0.1"/>
														<xs:maxInclusive value="80.0"/>
														<xs:fractionDigits value="1"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
											<xs:element name="ComposDeAzufreEnPetroleo">
												<xs:annotation>
													<xs:documentation>Condicional tratándose de sujetos que hayan manifestado ser “contratista” o “asignatario” en el elemento “TipoCaracter" en caso de que haya seleccionado el producto PR08, para expresar el porcentaje de azufre en el petróleo. Deberá tener un valor mínimo de 0.1 a 10.0.</xs:documentation>
												</xs:annotation>
												<xs:simpleType>
													<xs:restriction base="xs:decimal">
														<xs:minInclusive value="0.1"/>
														<xs:maxInclusive value="10.0"/>
														<xs:fractionDigits value="1"/>
														<xs:whiteSpace value="collapse"/>
													</xs:restriction>
												</xs:simpleType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="GasNatural" minOccurs="0">
									<xs:complexType>
										<xs:sequence>
											<xs:element name="GasNaturalOCondensados" minOccurs="2" maxOccurs="10">
												<xs:annotation>
													<xs:documentation>Nodo condicional, tratándose de sujetos que hayan manifestado “contratista” o “asignatario” en Carácter, en caso de que haya seleccionado los productos PR09 o PR10 para registrar la información detallada de la composición del gas natural o de los condensados. La suma de la fracción molar de todos los componentes debe ser igual a 1.</xs:documentation>
												</xs:annotation>
												<xs:complexType>
													<xs:sequence>
														<xs:element name="ComposGasNaturalOCondensados" type="t_claveComplementoGNC">
															<xs:annotation>
																<xs:documentation>Requerido en caso de que haya seleccionado los productos PR09 o PR10, para expresar cada componente en la mezcla, conforme a lo señalado en el catálogo t_claveComplementoGNC, en la sección 4. “VALIDACIONES ADICIONALES A REALIZAR”, subsección 4.3 “Tipo definido para Gas Natural o Condensados”. Únicamente para quienes se hayan ostentado con el carácter de contratista o asignatario. Este campo deberá repetirse cuantos componentes tenga el gas natural o el condensado.
																</xs:documentation>
															</xs:annotation>
														</xs:element>
														<xs:element name="FraccionMolar">
															<xs:annotation>
																<xs:documentation>Requerido para expresar la fracción molar por cada componente expresado en “ComposGasNaturalOCondensados”. Deberá tener un valor mínimo de 0 a 0.999 por cada componente de la mezcla. La suma de la fracción molar de todos los componentes debe ser igual a 1.
																</xs:documentation>
															</xs:annotation>
															<xs:simpleType>
																<xs:restriction base="xs:decimal">
																	<xs:minInclusive value="0"/>
																	<xs:maxInclusive value="0.999"/>
																	<xs:fractionDigits value="3"/>
																	<xs:whiteSpace value="collapse"/>
																</xs:restriction>
															</xs:simpleType>
														</xs:element>
														<xs:element name="PoderCalorifico">
															<xs:annotation>
																<xs:documentation>Requerido para expresar el poder calorífico por cada componente expresado en “ComposGasNaturalOCondensados”, expresado en BTU/pie cúbico para el gas natural y MMBTU tratándose de condensados.</xs:documentation>
															</xs:annotation>
															<xs:simpleType>
																<xs:restriction base="xs:decimal">
																	<xs:maxInclusive value="150000.000"/>
																	<xs:minInclusive value="0.001"/>
																	<xs:fractionDigits value="3"/>
																	<xs:whiteSpace value="collapse"/>
																</xs:restriction>
															</xs:simpleType>
														</xs:element>
													</xs:sequence>
													<xs:assert test="if ((Covol:ClaveProducto = 'PR09' or Covol:ClaveProducto = 'PR10')) then (Covol:GasNatural/Covol:ComposGasNaturalOCondensados and Covol:GasNatural/Covol:FraccionMolar and Covol:GasNatural/Covol:PoderCalorifico) else not(Covol:GasNatural/Covol:ComposGasNaturalOCondensados and Covol:GasNatural/Covol:FraccionMolar and Covol:GasNatural/Covol:PoderCalorifico)"/>
												</xs:complexType>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="Otros" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Condicional cuando se haya seleccionado el producto PR15 o PR20 y el subproducto SP20 para expresar componentes diferentes a los productos señalados en el catálogo.</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:string">
											<xs:minLength value="1"/>
											<xs:maxLength value="30"/>
										</xs:restriction>
									</xs:simpleType>
								</xs:element>
							</xs:choice>
							<xs:element name="MarcaComercial" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Opcional para expresar la marca comercial de los petrolíferos.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:minLength value="2"/>
										<xs:maxLength value="200"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Marcaje" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Opcional para expresar la sustancia química empleada como marcador.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:minLength value="2"/>
										<xs:maxLength value="40"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ConcentracionSustanciaMarcaje" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Condicional para expresar la concentración de la sustancia cuando se haya manifestado marcaje. Se mide en ppm.</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:int">
										<xs:minInclusive value="1"/>
										<xs:maxInclusive value="1000"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TANQUE" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Esta sección se debe declarar por cada uno de los tanques en caso de que hayan manifestado número de tanques mayor que cero en “NumeroTanques”.</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="ClaveIdentificacionTanque">
											<xs:annotation>
												<xs:documentation>Requerido para expresar la clave de identificación de cada tanque o en su caso módulo, controlado por el contribuyente, conforme a la sección 5. “CLAVES”, subsección 5.2.
												</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:whiteSpace value="collapse"/>
													<xs:pattern value="TQS[-]{1}ACA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}AUP[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ALM[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ACL[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ASN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ACO[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}BSP[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}BDE[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}CMN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}COM[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}CON[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}DEN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}DIS[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}EMA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ESN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}EDS[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}ESA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}EXO[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}EXP[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}EXT[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}GSH[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}LON[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}RPO[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}MNA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}PTA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}PDD[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}PGN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}RCN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}REF[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}RGN[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}SIS[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}SFO[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}SDA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}TDA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}TDD[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}TRE[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}TRA[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}TDP[-]{1}[0-9]{4}"/>
													<xs:pattern value="TQS[-]{1}USP[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ACA[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}AUP[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ALM[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ACL[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ASN[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ACO[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}BSP[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}BDE[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}CMN[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}COM[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}CON[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}DEN[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}DIS[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}EMA[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ESN[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}EDS[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}ESA[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}EXO[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}EXP[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}EXT[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}GSH[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}LON[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}RPO[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}MNA[-]{1}[0-9]{4}"/>
													<xs:pattern value="CTQ[-]{1}PTA[-]{1}[0-9]{4}"/>
