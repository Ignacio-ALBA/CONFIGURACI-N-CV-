						<xs:assert test="if (Covol:ClaveProducto = 'PR11') then (Covol:Turbosina/Covol:TurbosinaConCombustibleNoFosil) else not(Covol:Turbosina/Covol:TurbosinaConCombustibleNoFosil)"/>
