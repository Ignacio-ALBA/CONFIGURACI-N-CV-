						(Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Almacenamiento/alm:EXTRANJERO/alm:PermisoImportacion) else true()"/>
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_CDLRGN/CDLRGN:EXTRANJERO) ) then 
						 (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_CDLRGN/CDLRGN:EXTRANJERO/CDLRGN:PermisoImportacionOExportacion) else true()"/>
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Comercializacion/co:EXTRANJERO) ) then  
						(Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Comercializacion/co:EXTRANJERO/co:PermisoImportacionOExportacion) else true()"/>
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Distribucion/dis:EXTRANJERO) ) then  
						(Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Distribucion/dis:EXTRANJERO/dis:PermisoImportacionOExportacion) else true()"/>	
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Expendio/exp:EXTRANJERO) ) then  
						(Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Expendio/exp:EXTRANJERO/exp:PermisoImportacion) else true()"/>		
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Extraccion/ext:EXTRANJERO) ) then 
						 (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Extraccion/ext:EXTRANJERO/ext:PermisoExportacion) else true()"/>	
						<xs:assert test="if (Covol:ClaveProducto != 'PR20' and (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Refinacion/ref:EXTRANJERO) ) then 
						 (Covol:REPORTEDEVOLUMENMENSUAL/Covol:ENTREGAS/Covol:Complemento/Covol:Complemento_Refinacion/ref:EXTRANJERO/ref:PermisoImportacionOExportacion) else true()"/>	
						
						<xs:assert test="if (string-length(Covol:Marcaje)>0  ) then (Covol:ConcentracionSustanciaMarcaje) else not(Covol:ConcentracionSustanciaMarcaje)"/>
