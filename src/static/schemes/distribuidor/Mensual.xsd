																		<xs:documentation>Unidad de medida asociada al valor numérico.</xs:documentation>
																	</xs:annotation>
																</xs:element>
															</xs:sequence>
														</xs:complexType>
													</xs:element>
													<xs:element name="PoderCalorifico" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Requerido tratándose de sujetos que hayan seleccionado el producto PR09 para registrar el poder calorífico del gas natural entregado en el mes, expresado en Megajoule tratándose de permisionarios y usuarios y en BTU tratándose de contratistas y asignatarios.</xs:documentation>
														</xs:annotation>
