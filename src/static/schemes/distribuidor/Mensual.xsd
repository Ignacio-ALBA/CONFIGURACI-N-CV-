										</xs:element>
										<xs:element name="ENTREGAS">
											<xs:annotation>
												<xs:documentation>En esta sección se deben declarar los registros de los volúmenes de las operaciones de entrega de los hidrocarburos o petrolíferos.</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="TotalEntregasMes">
														<xs:annotation>
															<xs:documentation>Requerido para expresar el número total de registros de volumen producido de hidrocarburos, entregado por ventas, autoconsumo o por prestaciones de servicio en el mes, incluyendo ductos de entrada y salida a medios de almacenamiento, ductos de carga y descarga de medios de transporte.</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
