						<xs:assert test="if (Covol:ClaveProducto = 'PR07') then (Covol:ClaveSubProducto ='SP16' or Covol:ClaveSubProducto ='SP17' ) and (Covol:Gasolina)

		else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR16') then (Covol:ClaveSubProducto ='SP48') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR17') then (Covol:ClaveSubProducto ='SP45' or Covol:ClaveSubProducto ='SP46') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR18') then (Covol:ClaveSubProducto ='SP26') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR19') then (Covol:ClaveSubProducto ='SP42') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR20') then (Covol:ClaveSubProducto ='SP20' or Covol:ClaveSubProducto = 'SP49') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR12') then not(Covol:ClaveSubProducto) else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR13') then (Covol:ClaveSubProducto ='SP30' or Covol:ClaveSubProducto ='SP31' or Covol:ClaveSubProducto ='SP32' or Covol:ClaveSubProducto ='SP33') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR11') then (Covol:ClaveSubProducto ='SP34' or Covol:ClaveSubProducto ='SP35') and (Covol:Turbosina) else not(Covol:Turbosina)"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR10') then not(Covol:ClaveSubProducto) else true() "/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR14') then not(Covol:ClaveSubProducto) else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR09') then (Covol:ClaveSubProducto ='SP27' or Covol:ClaveSubProducto ='SP28' or Covol:ClaveSubProducto ='SP29' or Covol:ClaveSubProducto ='SP37' or Covol:ClaveSubProducto ='SP38' or Covol:ClaveSubProducto ='SP41' or Covol:ClaveSubProducto ='SP42' or Covol:ClaveSubProducto ='SP43' or Covol:ClaveSubProducto ='SP44' or Covol:ClaveSubProducto ='SP47') else true()"/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR15') then  (Covol:ClaveSubProducto ='SP20' or Covol:ClaveSubProducto ='SP21' or Covol:ClaveSubProducto ='SP36' or Covol:ClaveSubProducto ='SP39' or Covol:ClaveSubProducto ='SP40') else true() "/>
						<xs:assert test="if (Covol:ClaveProducto = 'PR03') then (Covol:ClaveSubProducto ='SP18' or Covol:ClaveSubProducto ='SP19' or Covol:ClaveSubProducto ='SP22' or Covol:ClaveSubProducto ='SP23' or Covol:ClaveSubProducto ='SP24' or Covol:ClaveSubProducto ='SP25' ) and (Covol:Diesel) else not(Covol:Diesel) "/>
						<!--<xs:assert test="if ((Covol:ClaveProducto = 'PR09' or Covol:ClaveProducto = 'PR10')) then (Covol:GasNatural) else not(Covol:GasNatural)"/>-->
