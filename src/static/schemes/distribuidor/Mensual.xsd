																<xs:element name="Complemento_Almacenamiento" type="alm:Complemento_Almacenamiento"/>
																<xs:element name="Complemento_CDLRGN" type="CDLRGN:Complemento_CDLRGN"/>
																<xs:element name="Complemento_Comercializacion" type="co:Complemento_Comercializacion"/>
																<xs:element name="Complemento_Distribucion" type="dis:Complemento_Distribucion"/>
																<xs:element name="Complemento_Expendio" type="exp:Complemento_Expendio"/>
																<xs:element name="Complemento_Extraccion" type="ext:Complemento_Extraccion"/>
																<xs:element name="Complemento_Refinacion" type="ref:Complemento_Refinacion"/>
															</xs:choice>
